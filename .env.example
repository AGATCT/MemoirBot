# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# 数据存储目录（可选，默认 ./data）
PERSONAL_AGENT_DATA_DIR=./data

# 宿主地址和端口
HOST=127.0.0.1
PORT=8000

# LLM 配置
LLM_MODEL=deepseek-v4-flash
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# 记忆提取配置
EXTRACTION_INTERVAL=5
DREAM_INTERVAL_HOURS=24
DREAM_MIN_SESSIONS=5
